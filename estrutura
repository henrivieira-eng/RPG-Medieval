class Missão:
    def __init__(self):
        self.inimigos = ["bandidos", "duendes", "ogros"]
        self.inimigo = random.choice(self.inimigos)
        self.quantidade_inimigos = random.randint(2, 5)
        self.descricao = f"Derrote {self.quantidade_inimigos} {self.inimigo}."
        self.progresso = 0

    def recompensa(self):
        if self.quantidade_inimigos == 2:
            return 20
        
        elif self.quantidade_inimigos == 3:
            return 30

        elif self.quantidade_inimigos == 4:
            return 40
        
        elif self.quantidade_inimigos == 5:
            return 50
    
    def progredir(self, jogador):
        self.progresso += 1

        if self.progresso == self.quantidade_inimigos:
            jogador.moedas += self.recompensa
            jogador.missao = None


class Loja:
    def __init__(self):
        self._itens = []

    def adicionar_item(self, item):
        self._itens.append(item)

    def remover_item(self, item):
        if len(self._itens) == 0:
            raise ValueError("Esse item não existe na loja.")
            
        else:
            self._itens.remove(item)

    def listar_itens(self):
        if len(self._itens) == 0:
            print("O estoque da loja está vazio.")
        
        else:
            for item in self._itens:
                print(f"{item.nome} | $ {item.preco}")

class Inventário:
    def __init__(self, capacidade):
        self.capacidade = capacidade
        self._itens = []

    def __add__(self, other):
        self.itens.append(other)
        
    def __sub__(self, other):
        if len(self._itens) == 0:
            raise ValueError("O inventário não pode ter uma quantidade negativa de itens.")
            
        else:
            self._itens.remove(other)

class Item:
    def __init__(self, nome, preco, tipo):
        self.nome = nome
        self.preco = preco
        self.tipo = tipo

class Equipamento(Item):
    def __init__(self, nome, preco, tipo, bonus_forca=0, bonus_resistencia=0, bonus_agilidade=0, bonus_inteligencia=0):
        super().__init__(nome, preco, tipo)
        self.bonus_forca = bonus_forca
        self.bonus_resistencia = bonus_resistencia
        self.bonus_agilidade = bonus_agilidade
        self.bonus_inteligencia = bonus_inteligencia

class Poção(Item):
    def __init__(self, nome, preco, cura):
        super().__init__(nome, preco)
        self.cura = cura
