class Missão(LogMixin):
    """
    Representa uma missão gerada aleatoriamente que o jogador pode cumprir para ganhar moedas.
    
    Attributes:
        inimigos (list): Qual tipo de inimigo deve ser derrotado.
        quantidade_inimigos (int): Quantos inimigos devem ser derrotados.
        descricao (str): O que a missão pede (quantidade de inimigos de um determinado tipo que devem ser derrotados).
        progresso (int): Quantos inimigos já foram derrotados.
    """

    def __init__(self):
        self.inimigos = ["bandidos", "duendes", "ogros"]
        self.inimigo = random.choice(self.inimigos)
        self.quantidade_inimigos = random.randint(2, 5)
        self.descricao = f"Derrote {self.quantidade_inimigos} {self.inimigo}."
        self.progresso = 0

    def recompensa(self):
        """
        Calcula a recompensa em moedas baseada na quantidade de inimigos sorteados.
        """

        return self.quantidade_inimigos * 10
    
    def progredir(self, jogador):
        """
        Incrementa o progresso da missão. Se concluída, premia o jogador com moedas.
        
        Args:
            jogador (Personagem): O herói que está realizando a missão.
        """

        self.progresso += 1

        self.log(f"O personagem progrediu na missão atual.")

        if self.progresso == self.quantidade_inimigos:
            jogador._moedas += self.recompensa()
            jogador._missao_ativa = None

            self.log(f"O personagem completou uma missão.")

class Loja(LogMixin):
    """
    Gerencia um catálogo de itens que podem ser comprados pelo jogador e que o jogador pode vender posteriormente.
    
    Attributes:
        nome (str): Nome da loja de acordo com o que ela vende (Arsenal, Armaduraria, Botica)
        _itens (list): Lista de itens disponíveis na loja.
    """

    def __init__(self, nome):
        self.nome = nome
        self._itens = []

    def adicionar_item(self, item):
        """
        Adiciona um item ao catálogo da loja.
        """

        self._itens.append(item)

        self.log(f"{item.nome} foi adicionado(a) na loja.")

    def remover_item(self, item):
        """
        Remove um item do catálogo da loja.
        """

        if len(self._itens) == 0 or item not in self._itens:
            raise ValueError("Esse item não existe na loja.")
        else:
            self._itens.remove(item)

            self.log(f"{item.nome} foi removido(a) da loja.")

    def listar_itens(self) -> None:
        """
        Exibe todos os itens disponíveis e seus respectivos preços.
        """

    def listar_itens(self):

        if len(self._itens) == 0:
            return None

        for i, item in enumerate(self._itens, start=1):
            print(f"{i} | {item.nome} | $ {item.preco}")

class Inventario:
    """
    Controla o armazenamento de itens coletados pelo personagem através de sobrecarga de operadores.
    
    Attributes:
        capacidade (int): Quantidade de itens que podem ser guardados pelo personagem.
        _itens (list): Lista de itens guardados pelo personagem.
    """

    def __init__(self):
        self.capacidade = 15
        self._itens = []

    def __add__(self, other):
        """
        Permite adicionar itens usando o operador "+" (ex: inventario + item).
        """

        if len(self._itens) >= self.capacidade:
            raise ValueError("Inventário cheio!")
        self._itens.append(other)
        
    def __sub__(self, other):
        """
        Permite remover itens usando o operador "-" (ex: inventario - item).
        """

        if len(self._itens) == 0:
            raise ValueError("O inventário está vazio.")
        else:
            self._itens.remove(other)

class Item:
    """
    Classe base para qualquer objeto negociável ou utilizável no jogo.

    Attributes:
        nome (str): Nome do item.
        preco (int): Preço do item.
        tipo (str): Tipo do item (arma/armadura/escudo).
    """

    def __init__(self, nome, preco, tipo):
        self.nome = nome
        self.preco = preco
        self.tipo = tipo

class Equipamento(Item):
    """
    Representa armas ou armaduras que alteram os atributos das classes de Personagem.
    """

    def __init__(self, nome, preco, tipo, bonus_forca=0, bonus_resistencia=0, bonus_agilidade=0, bonus_inteligencia=0):
        super().__init__(nome, preco, tipo)
        self.bonus_forca = bonus_forca
        self.bonus_resistencia = bonus_resistencia
        self.bonus_agilidade = bonus_agilidade
        self.bonus_inteligencia = bonus_inteligencia

class Pocao(Item):
    """
    Representa consumíveis de cura de vida.

    Attributes:
        cura (int): Quantidade de pontos de vida que a poção consegue restaurar no personagem.
    """

    def __init__(self, nome, preco, cura):
        super().__init__(nome, preco, "Poção")
        self.cura = cura
