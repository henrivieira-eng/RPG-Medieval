import abc
import random

class LogMixin:
    def log(self, mensagem):
        print(f"[LOG {self.__class__.__name__}] {mensagem}")

class Entidade(abc.ABC):
    def __init__(self, nome):
        self.nome = nome
        self._vida = 100
        self._vida_max = 100

    @abc.abstractmethod
    def calcular_dano(self):
        pass

    def atacar(self, alvo):
        alvo.receber_dano(self.dano)
        print(f"O {self.nome} atacou você!")

    def receber_dano(self, dano):
        self._vida -= dano

        if self._vida < 0:
            self._vida = 0

class Personagem(Entidade):
    def __init__(self, nome, arma=None, armadura=None, escudo=None):
        super().__init__(nome)
        self._moedas = 0
        self._missao_ativa
        self._arma = arma
        self._armadura = armadura
        self._escudo = escudo
        self.inventario = Inventário()
        self.forca = 0
        self.resistencia = 0
        self.agilidade = 0
        self.inteligencia = 0

    def adquirir_missao(self):
        if self.missao_ativa is not None:
            raise ValueError("Você tem uma missão pendente no momento.")
        
        else:
            self.missao_ativa = Missão()

    def comprar(self, loja, item):
        if self._moedas >= item.preco:
            self._moedas -= item.preco

        else:
            raise ValueError("Você não tem moedas suficientes.")

        self.inventario + item
        loja.remover_item(item)

    def vender(self, loja, item):
        self._moedas += item.preco
        self.inventario - item
        loja.adicionar_item(item)

    def tomar_pocao(self, pocao):
        self._vida += pocao.cura

        if self._vida > self._vida_max:
            self._vida = self._vida_max

