import abc
import random
import csv

class LogMixin:
    """
    Mixin que adiciona a funcionalidade de registro automático às classes e os salva em csv.
    """

    ARQUIVO_LOG = "logs.csv"

    def log(self, mensagem):
        with open(self.ARQUIVO_LOG, "a", newline="", encoding="utf-8") as arquivo:
            writer = csv.writer(arquivo)

            writer.writerow([
                self.__class__.__name__,
                mensagem
            ])

class Entidade(abc.ABC, LogMixin):
    """
    Classe abstrata que representa qualquer ser vivo no jogo (Personagem e Inimigo).
    
    Attributes:
        nome (str): Nome da entidade.
        _vida (int): Quantidade de vida atual da entidade.
        _vida_max (int): Vida máxima da entidade.
    """

    def __init__(self, nome):
        self.nome = nome
        self._vida = 100
        self._vida_max = 100

    def atacar(self, alvo):
        """
        Realiza um ataque contra outra entidade.
        
        Args:
            alvo (Entidade): A entidade que receberá o ataque.
        """

        alvo.receber_dano(self.dano)

        self.log(f"{self.nome} atacou o personagem.")

    def receber_dano(self, dano):
        """
        Reduz a vida da entidade com base no dano recebido, respeitando o limite mínimo de 0.
        
        Args:
            dano (float): Quantidade de dano a ser subtraída da vida.
        """

        self._vida -= dano
        if self._vida < 0:
            self._vida = 0

        self.log(f"{self.nome} recebeu {dano} pontos de dano.")

class Personagem(Entidade):
    """
    Classe base para os heróis controlados pelo jogador. Herda de Entidade.
    
    Attributes:
        saveid (None): Variável que futuramente armazenará o id de save.
        moedas (int): Quantidade de moedas que o personagem possui.
        _missao_ativa (Missão): Missão atual do personagem.
        _arma (Equipamento): Arma equipada do personagem.
        _armadura (Equipamento): Armadura equipada do personagem.
        _escudo (Equipamento): Escudo equipado do personagem.
        inventario (Inventário): Conjunto de itens guardados que o personagem possui.
        forca (int): Força atual do personagem.
        resistencia (int): Resistência atual do personagem.
        agilidade (int): Agilidade atual do personagem.
        inteligencia (int): Inteligência atual do personagem.
    """

    def __init__(self, nome, arma=None, armadura=None, escudo=None):
        super().__init__(nome)
        self.saveid = None
        self._moedas = 0
        self._missao_ativa = None
        self._arma = arma
        self._armadura = armadura
        self._escudo = escudo
        self.inventario = Inventario()
        self.forca = 0
        self.resistencia = 0
        self.agilidade = 0
        self.inteligencia = 0

    @abc.abstractmethod
    def calcular_dano(self):
        """
        Calcula e retorna o dano causado pela entidade com base em seus atributos.
        """

        pass

    @abc.abstractmethod
    def equipar(self, equipamento):
        """
        Equipa uma armadura ou arma ou escudo e soma os bônus aos atributos do personagem.
        
        Args:
            equipamento (Equipamento): O equipamento a ser equipado.

        Raises:
            ValueError: Se já houver um equipamento do mesmo tipo equipado ou se o equipamento não for compatível.
        """
        
        pass
    
    @abc.abstractmethod
    def desequipar(self, equipamento):
        """
        Remove o equipamento e subtrai os bônus concedidos anteriormente.

        Args:
            equipamento (Equipamento): O equipamento a ser desequipado.

        Raises:
            ValueError: Se o equipamento não estiver equipado.
        """
        
        pass

    def adquirir_missao(self):
        """
        Atribui uma nova missão aleatória ao personagem.
        
        Raises:
            ValueError: Se o personagem já possuir uma missão em andamento.
        """

        if self._missao_ativa is not None:
            raise ValueError("Você tem uma missão pendente no momento.")
        else:
            self._missao_ativa = Missão()

        self.log("O personagem adquiriu uma nova missão.")

    def aplicar_bonus(self, equipamento):
        self.forca += equipamento.bonus_forca
        self.resistencia += equipamento.bonus_resistencia
        self.agilidade += equipamento.bonus_agilidade
        self.inteligencia += equipamento.bonus_inteligencia

    def remover_bonus(self, equipamento):
        self.forca -= equipamento.bonus_forca
        self.resistencia -= equipamento.bonus_resistencia
        self.agilidade -= equipamento.bonus_agilidade
        self.inteligencia -= equipamento.bonus_inteligencia

    def comprar(self, loja, item):
        """
        Compra um item de uma loja, pagando o valor e adicionando-o ao inventário.
        
        Args:
            loja (Loja): A instância da loja onde o item está.
            item (Item): O item a ser comprado.
            
        Raises:
            ValueError: Se o personagem não tiver moedas suficientes.
        """

        if self._moedas >= item.preco:
            self._moedas -= item.preco
            self.inventario + item
            loja.remover_item(item)

            self.log(f"O personagem comprou {item.nome}.")
            self.log(f"{item.nome} foi adicionado(a) no inventário do personagem.")
        else:
            raise ValueError("Você não tem moedas suficientes.")

    def vender(self, loja, item):
        """
        Vende um item do inventário para uma loja, recebendo o valor do item.
        
        Args:
            loja (Loja): A loja que receberá o item.
            item (Item): O item a ser vendido.
        """

        self._moedas += item.preco
        self.inventario - item
        loja.adicionar_item(item)

        self.log(f"O personagem vendeu {item.nome}.")
        self.log(f"{item.nome} foi removido(a) do inventário do personagem.")

    def tomar_pocao(self, pocao):
        """
        Consome uma poção para recuperar vida, respeitando o limite máximo do personagem.
        
        Args:
            pocao (Poção): A poção a ser consumida.

        Raises:
            ValueError: se a vida do personagem estiver cheia
        """

        if self._vida < self._vida_max:
            self._vida += pocao.cura
            if self._vida > self._vida_max:
                self._vida = self._vida_max
        
        else:
            raise ValueError("Sua vida está cheia.")

            self.log(f"O personagem tomou {pocao.nome}.")

class Lutador(Personagem):
    """
    Classe de Personagem focada em grande força.
    """

    def __init__(self, nome):
        super().__init__(nome)
        self._vida = 180
        self._vida_max = 180
        self._armadura = Equipamento("Armadura de couro", 0, "Armadura", 0, 1)
        self.forca = 10
        self.resistencia = 9
        self.agilidade = 5
        self.inteligencia = 6

    def equipar(self, equipamento):
        if equipamento.tipo == "Armadura":
            if self._armadura is None:
                self._armadura = equipamento
                self.aplicar_bonus(equipamento)

                self.log(f"O personagem equipou {equipamento.nome}.")

            else:
                raise ValueError("Você já tem uma armadura equipada.")

        else:
            raise ValueError("O equipamento não é compatível.")

    def desequipar(self, equipamento):
        if equipamento.tipo == "Armadura" and self._armadura is not None:
            self._armadura = None
            self.remover_bonus(equipamento)

            self.log(f"O personagem desequipou {equipamento.nome}.")
        
        else:
            raise ValueError("Você não tem esse equipamento equipado.")

    def calcular_dano(self):
        return (2 * self.forca) + self.resistencia + (0.5 * self.agilidade) + (0.5 * self.inteligencia)

    def atacar(self, alvo):
        dano = self.calcular_dano()
        alvo.receber_dano(dano)

        self.log(f"O personagem atacou {alvo.nome}.")

