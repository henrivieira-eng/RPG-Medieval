            self.agilidade += equipamento.bonus_agilidade
            self.inteligencia += equipamento.bonus_inteligencia

    def desequipar(self, equipamento):
        if (equipamento.tipo == "Espada") and self._arma is not None:
            self._arma = None
            
            self.forca -= equipamento.bonus_forca
            self.resistencia -= equipamento.bonus_resistencia
